# Copy this file to .env.production and fill in every value.
# NEVER commit .env.production to git.

# ─── Domain ──────────────────────────────────────────────────────────────────
# Must match your DNS A record pointing to the server IP.
DOMAIN=oikos.family
APP_BASE_URL=https://oikos.family

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=oikos
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=replace_with_strong_password

# ─── Redis ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
REDIS_PASSWORD=replace_with_strong_password

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_64_char_hex_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_ADDRESS=no-reply@oikos.family
EMAIL_FROM_NAME=Oikos
