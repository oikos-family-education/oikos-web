# apps/web/.env.e2e.example
#
# Template for the E2E test environment. Copy to `.env.e2e` (gitignored) and
# adjust if needed:
#
#   cp apps/web/.env.e2e.example apps/web/.env.e2e
#
# These variables are consumed by Playwright (global-setup.ts, playwright.config.ts).
# See doc/12-e2e-testing-plan.md §3.2 for context.

# Base URL the API exposes when the e2e stack is running.
# Matches the host-side port mapping in docker-compose.e2e.yml.
NEXT_PUBLIC_API_URL=http://localhost:8001

# Base URL the Next.js web server exposes when the e2e stack is running.
# Used as Playwright's `baseURL` in playwright.config.ts.
E2E_BASE_URL=http://localhost:3001

# Shared secret required to call the /api/v1/e2e/seed and /api/v1/e2e/reset
# endpoints. Must match the value the API container was started with.
# Generate a fresh value for shared environments: openssl rand -hex 16
E2E_SEED_SECRET=e2e-local-secret
